<?xml version="1.0" encoding="utf-8"?>
<!--
  Solution-level run settings for the VisioAutomation test projects.

  DeploymentEnabled=false tells MSTest's runner to execute tests in-place
  from each project's bin/<config>/ folder rather than copying them to a
  TestResults\<runId>\Out\ deployment folder. The data files referenced
  by [DeploymentItem] attributes are already CopyToOutputDirectory=Always
  in the csprojs, so they're alongside the test DLL anyway.

  Without this, VS Test Explorer triggers deployment whenever it sees
  a [DeploymentItem] attribute, copies only the explicitly-listed files
  to the deployment folder, and tests fail to load runtime dependencies
  (e.g. System.Threading.Tasks.Extensions.dll) that the test DLL needs
  but that aren't enumerated in [DeploymentItem]s.

  VS Test Explorer auto-detects this file when it sits next to the .sln.
  CLI: pass /Settings:default.runsettings to vstest.console.exe.
-->
<RunSettings>
  <MSTest>
    <DeploymentEnabled>False</DeploymentEnabled>
  </MSTest>
</RunSettings>
