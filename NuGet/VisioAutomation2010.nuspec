    <readme>README.md</readme>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>VisioAutomation helps developers to control Visio from .NET languages.
It simplifies common tasks and makes it easier to build Visio add-ins and automation/scripting tools.
</description>
    <releaseNotes>See https://github.com/saveenr/VisioAutomation/blob/master/NuGet/CHANGELOG.md</releaseNotes>
    <copyright>Copyright SevenPens</copyright>
    <tags>Visio</tags>
    <dependencies>
      <group targetFramework="net452">
      </group>
    </dependencies>
    <frameworkAssemblies>
      <frameworkAssembly assemblyName="Microsoft.Office.Interop.Visio" />
    </frameworkAssemblies>
  </metadata>
